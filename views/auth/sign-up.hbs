
<div class="auth-page">
  <div class="container page">
    <div class="row">
      <div class="col-md-6 offset-md-3 col-xs-12">
        <h1 class="text-xs-center">Sign up</h1>
        <p class="text-xs-center">
          <a href="/sign-in" hx-get="/htmx/sign-in" hx-target="#app-body" hx-push-url="/sign-in">Have an account?</a>
        </p>

        <div id="sign-up-form-messages">
          {{> error-message errors=errors}}
        </div>

        <form hx-post="/htmx/sign-up"
              hx-target="#sign-up-form-messages"
              hx-swap="innerHTML">
          <fieldset class="form-group">
            <input class="form-control form-control-lg" type="text" name="username" placeholder="Username" value="{{values.username}}" />
          </fieldset>
          <fieldset class="form-group">
            <input class="form-control form-control-lg" type="email" name="email" placeholder="Email" value="{{values.email}}" />
          </fieldset>
          <fieldset class="form-group">
            <input class="form-control form-control-lg" type="password" name="password" placeholder="Password" />
          </fieldset>
          <button class="btn btn-lg btn-primary pull-xs-right" type="submit">Sign up</button>
        </form>
      </div>
    </div>
  </div>
</div>
